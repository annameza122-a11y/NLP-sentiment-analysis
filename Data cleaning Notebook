        "# Function: Parse review files\n",
        "# This function reads a .review file and extracts each review's text and rating.\n",
        "# It uses BeautifulSoup to handle XML-like structure and returns a list of (text, rating) tuples.\n",
        "\n",
        "def parse_review_file(filepath):\n",
        "    \"\"\"\n",
        "    Parse a .review file into a list of (text, rating) tuples.\n",
        "    Uses BeautifulSoup for robust parsing of XML-like files.\n",
        "    \"\"\"\n",
        "    reviews = []   # Initialize an empty list to store extracted (text, rating) pairs\n",
        "\n",
        "    # Read the entire file as raw text (ignore encoding errors)\n",
        "    with open(filepath, 'r', encoding='utf-8', errors='ignore') as f:\n",
        "        content = f.read()\n",
        "\n",
        "    # Wrap content in a <root> tag to ensure valid XML structure for parsing\n",
        "    soup = BeautifulSoup(f\"<root>{content}</root>\", 'lxml')\n",
        "\n",
        "    # Iterate through every <review> block in the file\n",
        "    for review in soup.find_all('review'):\n",
        "        text_tag = review.find('review_text')\n",
        "        rating_tag = review.find('rating')\n",
        "\n",
        "        # Only process reviews that contain both text and rating\n",
        "        if text_tag and rating_tag:\n",
        "            text = text_tag.get_text(strip=True)     # Extract clean review text\n",
        "            rating = rating_tag.get_text(strip=True) # Extract rating value\n",
        "            if text:\n",
        "                reviews.append((text, rating))       # Store as a tuple (text, rating)\n",
        "\n",
        "    return reviews\n",
        "\n",
        "\n",
        "# Test the function on one file\n",
        "# Build the path to the first category's positive reviews file\n",
        "sample_file = os.path.join(raw_dir, categories[0], 'positive.review')\n",
