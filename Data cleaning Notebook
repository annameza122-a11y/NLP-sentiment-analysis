      "cell_type": "code",
      "source": [
        "#Remove outliers\n",
        "def remove_outliers(reviews, min_words=10, max_words=500):\n",
        "    \"\"\"\n",
        "    Remove or fix reviews that fall outside acceptable bounds:\n",
        "    - Too short (under min_words): not enough context for the model\n",
        "    - Too long (over max_words): truncate to avoid memory issues\n",
        "    - Exact duplicates: remove to avoid training bias\n",
        "    \"\"\"\n",
        "    cleaned = []\n",
        "    seen = set()\n",
        "    stats = {'too_short': 0, 'truncated': 0, 'duplicate': 0, 'kept': 0}\n",
        "\n",
        "    for text, label, category in reviews:\n",
        "        words = text.split()\n",
        "\n",
        "        if len(words) < min_words:\n",
        "            stats['too_short'] += 1\n",
        "            continue\n",
        "\n",
        "        if len(words) > max_words:\n",
        "            text = ' '.join(words[:max_words])\n",
        "            stats['truncated'] += 1\n",
        "\n",
        "        if text in seen:\n",
        "            stats['duplicate'] += 1\n",
        "            continue\n",
        "\n",
        "        seen.add(text)\n",
        "        cleaned.append((text, label, category))\n",
        "        stats['kept'] += 1\n",
        "\n",
        "    return cleaned, stats\n",
        "\n",
        "\n",
        "positive_filtered, pos_stats = remove_outliers(positive_cleaned)\n",
        "negative_filtered, neg_stats = remove_outliers(negative_cleaned)\n",
        "\n",
        "print(\"Outlier Removal Results:\")\n",
        "print(f\"\\n  Positive: {pos_stats}\")\n",
        "print(f\"  Negative: {neg_stats}\")"
      ],
