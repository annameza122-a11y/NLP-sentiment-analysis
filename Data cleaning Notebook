        "# Clean text\n",
        "# This function applies a full text-cleaning pipeline to prepare raw review text\n",
        "# for NLP processing. It standardizes, removes noise, and normalizes the input.\n",
        "def clean_text(text):\n",
        "    \"\"\"\n",
        "    Full text cleaning pipeline:\n",
        "    1. Lowercase\n",
        "    2. Remove HTML tags\n",
        "    3. Remove URLs\n",
        "    4. Expand contractions\n",
        "    5. Remove punctuation\n",
        "    6. Remove standalone numbers\n",
        "    7. Remove extra whitespace\n",
        "    \"\"\"\n",
        "\n",
        "    # Return empty string if input is missing or not a valid string\n",
        "    if not text or not isinstance(text, str):\n",
        "        return \"\"\n",
        "\n",
        "    # 1. Lowercase — ensures consistent text representation\n",
        "    text = text.lower()\n",
        "\n",
        "    # 2. Remove HTML tags — strips <br>, <p>, <div>, etc.\n",
        "    text = BeautifulSoup(text, 'lxml').get_text()\n",
        "\n",
        "    # 3. Remove URLs — removes http://, https://, and www links\n",
        "    text = re.sub(r'http\\S+|www\\.\\S+', '', text)\n",
        "\n",
        "    # 4. Expand contractions — converts \"can't\" → \"cannot\", \"it's\" → \"it is\"\n",
        "    contractions = {\n",
        "        \"won't\": \"will not\", \"can't\": \"cannot\",\n",
        "        \"don't\": \"do not\", \"didn't\": \"did not\",\n",
        "        \"doesn't\": \"does not\", \"isn't\": \"is not\",\n",
        "        \"wasn't\": \"was not\", \"weren't\": \"were not\",\n",
        "        \"haven't\": \"have not\", \"hadn't\": \"had not\",\n",
        "        \"wouldn't\": \"would not\", \"couldn't\": \"could not\",\n",
        "        \"shouldn't\": \"should not\", \"i'm\": \"i am\",\n",
        "        \"i've\": \"i have\", \"i'll\": \"i will\",\n",
        "        \"i'd\": \"i would\", \"it's\": \"it is\",\n",
        "        \"that's\": \"that is\", \"they're\": \"they are\",\n",
        "        \"we're\": \"we are\", \"you're\": \"you are\",\n",
        "    }\n",
        "    # Replace each contraction with its expanded form\n",
        "    for k, v in contractions.items():\n",
        "        text = text.replace(k, v)\n",
        "\n",
        "    # 5. Remove punctuation — keeps only letters, numbers, and spaces\n",
        "    text = re.sub(r\"[^a-z0-9\\s]\", \" \", text)\n",
        "\n",
        "    # 6. Remove standalone numbers — removes isolated numeric tokens\n",
        "    text = re.sub(r'\\b\\d+\\b', '', text)\n",
        "\n",
        "    # 7. Remove extra whitespace — collapses multiple spaces into one\n",
        "    text = re.sub(r'\\s+', ' ', text).strip()\n",
        "\n",
        "    return text\n",
        "\n",
        "\n",
        "#Test the function\n",
        "test = \"This product is GREAT!!! Can't believe it... 10/10 visit http://amazon.com\"\n",
        "\n",
        "print(\"Cleaning test:\")\n",
        "print(f\"  Before : {test}\")\n",
        "print(f\"  After  : {clean_text(test)}\")\n"
